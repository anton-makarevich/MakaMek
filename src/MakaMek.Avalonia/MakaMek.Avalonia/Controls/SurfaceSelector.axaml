<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Sanet.MakaMek.Avalonia.Controls"
             xmlns:models="clr-namespace:Sanet.MakaMek.Map.Models;assembly=Sanet.MakaMek.Map"
             x:Class="Sanet.MakaMek.Avalonia.Controls.SurfaceSelector">
    <Border Background="{StaticResource OverlayTransparentBrush}"
            CornerRadius="8"
            Padding="8">
        <StackPanel x:Name="ButtonsContainer" Spacing="4">
            <Button x:Name="GroundButton"
                    Classes="outline"
                    Click="GroundButton_OnClick"/>
            <Button x:Name="BridgeButton"
                    Classes="outline"
                    Click="BridgeButton_OnClick"/>
        </StackPanel>
    </Border>
</UserControl>
