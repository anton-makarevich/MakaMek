<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sanet.MakaMek.Presentation.ViewModels;assembly=Sanet.MakaMek.Presentation"
             xmlns:templatedControls="clr-namespace:Sanet.MakaMek.Avalonia.Views.TemplatedControls"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Extensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="viewModels:SettingsViewModel"
             x:Class="Sanet.MakaMek.Avalonia.Views.Settings.SettingsView">

    <Grid Margin="10" RowDefinitions="Auto,*">
        <!-- Toolbar with Back Button -->
        <templatedControls:ToolBar
            Title="{extensions:Localize 'SettingsView_Title'}"
            TitleAlignment="Center"
            LeftCommand="{Binding BackCommand}"
            LeftIcon="{StaticResource BackArrowIcon}"/>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" Margin="0,10,0,0">
            <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Center">
                
                <!-- Data Section -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding DataSectionTitle}"
                                   Classes="h3"/>
                        <TextBlock Text="{Binding CacheStatusLabel}"
                                   Classes="body"/>
                        <TextBlock Text="{Binding CacheStatus}"
                                   Classes="body"
                                   FontWeight="SemiBold"/>
                        <Button Content="{Binding ClearCacheButton}"
                                Command="{Binding ClearCacheCommand}"
                                IsEnabled="{Binding !IsBusy}"
                                Classes="primary"
                                HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ClearCacheDescription}"
                                   TextWrapping="Wrap"
                                   Classes="body"
                                   Foreground="Gray"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
