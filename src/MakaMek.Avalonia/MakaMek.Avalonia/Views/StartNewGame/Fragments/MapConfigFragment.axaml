<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels1="clr-namespace:Sanet.MakaMek.Presentation.ViewModels;assembly=Sanet.MakaMek.Presentation"
             xmlns:converters="clr-namespace:Sanet.MakaMek.Avalonia.Converters"
             xmlns:extensions="clr-namespace:Sanet.MakaMek.Avalonia.Extensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sanet.MakaMek.Avalonia.Views.StartNewGame.Fragments.MapConfigFragment"
             x:DataType="viewModels1:MapConfigViewModel">
    <UserControl.Resources>
        <converters:AdaptiveGridConverter x:Key="AdaptiveGridConverter"/>
        <converters:SelectedItemToBrushConverter x:Key="SelectedItemToBrushConverter"/>
    </UserControl.Resources>
    
    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
        <!-- Tab 1: Select a Pre-existing Map -->
        <TabItem Header="{extensions:Localize 'MapConfig_SelectMap'}">
            <Grid RowDefinitions="*,Auto">
                <ItemsControl Grid.Row="0" ItemsSource="{Binding AvailableMaps}" Margin="8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels1:MapPreviewItem">
                            <Border Margin="8" Padding="8" CornerRadius="8"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    BorderBrush="{Binding IsSelected, 
                                        Converter={StaticResource SelectedItemToBrushConverter}}"
                                    Background="#1A000000"
                                    PointerPressed="OnMapItemPressed">
                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <Image Source="{Binding PreviewImage}" 
                                           MaxWidth="200" MaxHeight="200"
                                           Stretch="Uniform"/>
                                    <TextBlock Text="{Binding Name}" 
                                               HorizontalAlignment="Center"
                                               Classes="bodySmall"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ProgressBar Grid.Row="0"
                             IsVisible="{Binding IsLoadingMaps}"
                             IsIndeterminate="True"
                             VerticalAlignment="Top"/>
                <Button Grid.Row="1"
                        Command="{Binding LoadMapCommand}"
                        Content="{extensions:Localize 'MapConfig_LoadMap'}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="8"
                        Classes="primary"/>
            </Grid>
        </TabItem>
        
        <!-- Tab 2: Generate Map -->
        <TabItem Header="{extensions:Localize 'MapConfig_GenerateMap'}">
            <UniformGrid
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Rows="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, 
                                Path=Bounds.Size, 
                                Converter={StaticResource AdaptiveGridConverter}, 
                                ConverterParameter={x:Static converters:GridOrientation.Rows}}"
                Columns="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, 
                                Path=Bounds.Size, 
                                Converter={StaticResource AdaptiveGridConverter}, 
                                ConverterParameter={x:Static converters:GridOrientation.Columns}}"
            >
                <!-- Configuration Sliders -->
                <StackPanel Classes="verticalSpaced">
                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_Width'}" Classes="label"/>
                        <Slider Value="{Binding MapWidth}" Minimum="8" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding MapWidthFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_Height'}" Classes="label"/>
                        <Slider Value="{Binding MapHeight}" Minimum="8" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding MapHeightFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_ForestCoverage'}" Classes="label"/>
                        <Slider Value="{Binding ForestCoverage}" Minimum="0" Maximum="{Binding MaxForestCoverage}" TickFrequency="5" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding ForestCoverageFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup" IsVisible="{Binding HasForest}">
                        <TextBlock Text="{extensions:Localize 'MapConfig_LightWoods'}" Classes="label"/>
                        <Slider Value="{Binding LightWoodsPercentage}" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding LightWoodsFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_RoughTerrain'}" Classes="label"/>
                        <Slider Value="{Binding RoughCoverage}" Minimum="0" Maximum="{Binding MaxRoughCoverage}" TickFrequency="5" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding RoughCoverageFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_HillCoverage'}" Classes="label"/>
                        <Slider Value="{Binding HillCoverage}" Minimum="0" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding HillCoverageFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup" IsVisible="{Binding HasHills}">
                        <TextBlock Text="{extensions:Localize 'MapConfig_MaxElevation'}" Classes="label"/>
                        <Slider Value="{Binding MaxElevation}" Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding MaxElevationFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup">
                        <TextBlock Text="{extensions:Localize 'MapConfig_LakeCoverage'}" Classes="label"/>
                        <Slider Value="{Binding LakeCoverage}" Minimum="0" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding LakeCoverageFormatted}" Classes="bodySmall"/>
                    </StackPanel>

                    <StackPanel Classes="formGroup" IsVisible="{Binding HasLakes}">
                        <TextBlock Text="{extensions:Localize 'MapConfig_LakeMaxDepth'}" Classes="label"/>
                        <Slider Value="{Binding LakeMaxDepth}" Minimum="1" Maximum="3" TickFrequency="1" IsSnapToTickEnabled="True" Classes="gameSlider"/>
                        <!-- Note: StringFormat localization should be handled via ViewModel binding -->
                        <TextBlock Text="{Binding LakeMaxDepthFormatted}" Classes="bodySmall"/>
                    </StackPanel>
                </StackPanel>

                <!-- Map Preview -->
                <Panel
                    VerticalAlignment="Top"
                    Margin="5"
                        >
                        <Image VerticalAlignment="Top" MaxWidth="300" Source="{Binding PreviewImage}"
                               Stretch="Uniform"/>
                        <ProgressBar
                            IsVisible="{Binding IsGenerating}"
                            IsIndeterminate="True"/>
                </Panel>
                
            </UniformGrid>
        </TabItem>
    </TabControl>
</UserControl>
